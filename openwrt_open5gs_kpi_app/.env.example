# Open5GS KPI App - Environment Variables Reference
# 
# Copy this file to .env or source values directly.
# Example: source .env.example && python app.py

# ============================================================================
# Configuration
# ============================================================================

# Path to Open5GS sample.yaml configuration file
# If set, overrides hardcoded default path
# OPEN5GS_CONFIG=/home/user/open5gs/build/configs/sample.yaml

# ============================================================================
# Security & Credentials (RECOMMENDED)
# ============================================================================

# OpenWrt LuCI RPC password
# More secure than --openwrt-password CLI flag (which appears in 'ps' output)
# Only used if --openwrt-user also provided
# OPENWRT_PASSWORD=your_router_password_here

# ============================================================================
# Logging
# ============================================================================

# Python logging level (optional, overridden by --verbose/--debug CLI flags)
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL=DEBUG

# ============================================================================
# Example usage:
# ============================================================================
# 
# 1. Load custom config and password:
#    export OPEN5GS_CONFIG=/my/custom/config.yaml
#    export OPENWRT_PASSWORD=mysecret
#    python app.py --openwrt-user admin
#
# 2. Check loaded environment:
#    python app.py --debug --help
#
# ============================================================================
